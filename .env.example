# No OpenAI key needed — briefs are generated via the Cursor agent (local model).

# ZoomInfo API credentials (optional — pipeline works without them)
# Get your client ID and private key from your ZoomInfo admin portal.
ZOOMINFO_API_CLIENT_ID=your-zoominfo-client-id
ZOOMINFO_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----your-key-here-----END PRIVATE KEY-----
